{
  "name": "@votedforus/votes",
  "version": "1.1.9",
  "description": "TypeScript library and CLI for fetching and analyzing U.S. Congressional floor votes from House and Senate via Congress.gov API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js"
    }
  },
  "bin": {
    "vfu": "dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "build:typesfile": "tsc --ignoreConfig --ignoreDeprecations 6.0 src/types.ts -d --emitDeclarationOnly --module amd --outFile ./dist/types.bundle.d.ts --skipLibCheck --moduleResolution node10 && tsx src/cli/index.ts types --input ./dist/types.bundle.d.ts --output ./dist/types.bundle.d.ts",
    "build:typesfile:process": "tsx src/cli/index.ts types --input ./dist/types.bundle.d.ts --output ./dist/types.bundle.d.ts",
    "build:schema": "ts-to-zod --skipValidation",
    "bills:generate": "tsx src/cli/index.ts bills",
    "bill": "tsx src/cli/index.ts bill",
    "test": "node --test --experimental-test-coverage --import tsx src/**/*.test.ts",
    "test:types": "tsc --project tsconfig.json --noEmit",
    "test:types:test": "tsc --project tsconfig.test.json --noEmit",
    "test:api-congress": "node --test --experimental-test-coverage --import tsx src/api-congress-gov/*.test.ts",
    "test:cli": "node --test --experimental-test-coverage --import tsx src/cli/*.test.ts",
    "test:cli:types": "node --test --experimental-test-coverage --import tsx src/cli/types.test.ts",
    "test:congress": "node --test --experimental-test-coverage --import tsx src/congress/*.test.ts",
    "test:legislators": "node --test --experimental-test-coverage --import tsx src/legislators/*.test.ts",
    "test:utils": "node --test --experimental-test-coverage --import tsx src/utils/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test --import tsx src/**/*.test.ts",
    "test:compiled": "tsc --project tsconfig.test.json && node --test dist/**/*.test.js",
    "test:compiled:coverage": "tsc --project tsconfig.test.json && node --experimental-test-coverage --test dist/**/*.test.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "fast-xml-parser": "^5.5.10",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^25.5.2",
    "@votedforus/common": "^1.1.1",
    "fetch-mock": "^12.6.0",
    "mock-fs": "^5.5.0",
    "ts-node": "^10.9.2",
    "ts-to-zod": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "keywords": [
    "congress",
    "congress-api",
    "house",
    "senate",
    "representatives",
    "votes",
    "voting-records",
    "api",
    "legislation",
    "politics",
    "government",
    "usa",
    "bills"
  ],
  "author": "Scott Nath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VotedForUs/votes.git"
  },
  "homepage": "https://github.com/VotedForUs/votes#readme",
  "bugs": {
    "url": "https://github.com/VotedForUs/votes/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "zod": "^4.3.6"
  }
}
